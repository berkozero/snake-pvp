{
  "name": "snake-pvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun --watch server/index.ts",
    "server": "bun server/index.ts",
