{
  "name": "snake-pvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "scripts": {
    "dev:web": "bun run --cwd apps/web dev -- --host 127.0.0.1 --port 4173",
    "dev:server": "bun run --cwd apps/server dev",
    "server": "bun run --cwd apps/server start",
    "build:web": "bun run --cwd apps/web build",
    "build:server": "bun run check:server-vendor && bun run --cwd apps/server typecheck",
    "build": "bun run check:boundaries && bun run build:web && bun run build:server && bun run audit:web-dist",
    "test": "vitest run",
    "e2e": "playwright test",
    "test:all": "bun run test && bun run e2e",
    "check:boundaries": "bun scripts/check-boundaries.mjs",
    "audit:web-dist": "bun scripts/audit-web-dist.mjs",
    "check:server-vendor": "bun scripts/check-server-vendor.mjs",
    "verify": "bun run build && bun run test",
    "ai:bridge": "bun run --cwd tools/ai bridge",
    "ai:smoke": "bun run --cwd tools/ai smoke",
    "ai:dataset": "bun run --cwd tools/ai dataset",
    "ai:hard-states": "bun run --cwd tools/ai hard-states",
    "ai:analyze-losses": "bun run --cwd tools/ai analyze-losses",
    "ai:train": "bun run --cwd tools/ai train",
    "ai:eval": "bun run --cwd tools/ai eval",
    "ai:rl-train": "bun run --cwd tools/ai rl-train",
    "ai:rl-eval": "bun run --cwd tools/ai rl-eval",
    "ai:rl-selfplay-smoke": "bun run --cwd tools/ai rl-selfplay-smoke",
    "ai:export-policy": "bun run --cwd tools/ai export-policy",
    "ai:gate": "bun run --cwd tools/ai gate"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
